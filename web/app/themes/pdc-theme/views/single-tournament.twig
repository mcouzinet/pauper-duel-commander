{#
/**
 * Single Tournament Template
 *
 * Variables:
 * - post (Timber\Post)
 * - date_formatted (string)
 * - location, city (string)
 * - player_count (int)
 * - signup_url (string)
 * - top8 (array): [{place, player_name, commander_name, score, commander_image, decklist_url}]
 * - meta_commanders (array): [{name, count, percentage, image}]
 * - color_counts (array): {'W': n, ...}
 * - hero_image (string|null): art_crop of the winner's commander
 * - has_meta (bool)
 * - archive_url (string)
 */
#}

{% extends "layouts/base.twig" %}

{% block content %}

{# ---- Compact Hero ---- #}
<section class="tournament-hero relative overflow-hidden">
    {% if hero_image %}
        <div class="absolute inset-0 opacity-15">
            <img src="{{ hero_image }}" alt="" class="w-full h-full object-cover" aria-hidden="true">
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-bg-primary/70 via-bg-secondary/90 to-bg-primary"></div>
    {% else %}
        <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary"></div>
    {% endif %}

    <div class="container mx-auto px-4 sm:px-6 relative z-10 py-8 md:py-10">
        {# Back link + title row #}
        <div class="max-w-6xl mx-auto">
            <a href="{{ archive_url }}"
               class="inline-flex items-center gap-1.5 text-xs text-text-muted hover:text-brand-orange transition-colors mb-3 uppercase tracking-wider font-heading">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                {{ __('Tournois', 'pdc-theme') }}
            </a>

            <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
                <h1 class="text-2xl md:text-3xl font-heading font-bold text-magic-gradient leading-tight">
                    {{ post.title }}
                </h1>

                {# Inline meta badges #}
                <div class="flex flex-wrap items-center gap-2 sm:flex-shrink-0">
                    {% if date_formatted %}
                        <span class="tournament-badge tournament-badge--primary">
                            <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            {{ date_formatted }}
                        </span>
                    {% endif %}
                    {% if location %}
                        <span class="tournament-badge">
                            <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            {{ location }}{% if city %}, {{ city }}{% endif %}
                        </span>
                    {% endif %}
                    {% if player_count %}
                        <span class="tournament-badge">
                            <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            {{ player_count }} {{ __('joueurs', 'pdc-theme') }}
                        </span>
                    {% endif %}
                    {% if signup_url %}
                        <a href="{{ signup_url }}" target="_blank" rel="noopener noreferrer"
                           class="tournament-badge hover:border-brand-orange/50 hover:text-brand-orange transition-colors">
                            {{ __('Inscription', 'pdc-theme') }}
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                            </svg>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{# ---- Main content: Top 8 + Meta ---- #}
<section class="py-6 md:py-8 bg-bg-primary">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="max-w-6xl mx-auto">

            <div class="grid lg:grid-cols-5 gap-6 items-start">

                {# ===== Left: Top 8 (3 cols) ===== #}
                <div class="lg:col-span-3">
                    <h2 class="text-lg font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                        <span class="w-1 h-5 bg-brand-orange rounded-full"></span>
                        {{ __('Top 8', 'pdc-theme') }}
                    </h2>

                    {% if top8 %}
                        {# Winner highlight #}
                        {% set winner = top8|first %}
                        {% if winner and winner.place == 1 %}
                            <div class="tournament-winner mb-4">
                                <div class="flex items-center gap-3">
                                    <div class="tournament-place tournament-place--1">1</div>
                                    {% if winner.commander_image %}
                                        <div class="w-14 h-14 rounded-lg overflow-hidden shadow-lg ring-2 ring-yellow-500/30 flex-shrink-0">
                                            <img src="{{ winner.commander_image }}"
                                                 alt="{{ winner.commander_name }}"
                                                 class="w-full h-full object-cover"
                                                 loading="lazy">
                                        </div>
                                    {% endif %}
                                    <div class="flex-1 min-w-0">
                                        <p class="font-bold text-base text-yellow-300 truncate">{{ winner.player_name }}</p>
                                        <p class="text-sm text-yellow-200/60 font-mono truncate">{{ winner.commander_name }}</p>
                                    </div>
                                    {% if winner.score %}
                                        <span class="text-xs font-mono text-yellow-400/70 flex-shrink-0">{{ winner.score }}</span>
                                    {% endif %}
                                    {% if winner.decklist_url %}
                                        <a href="{{ winner.decklist_url }}"
                                           class="flex-shrink-0 px-2.5 py-1 bg-yellow-500/15 border border-yellow-500/30 rounded text-xs font-bold text-yellow-400 hover:bg-yellow-500/25 transition-colors uppercase tracking-wide">
                                            {{ __('Deck', 'pdc-theme') }}
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        {% endif %}

                        {# Remaining top 8 as compact rows #}
                        <div class="tournament-table">
                            {% for entry in top8 %}
                                {% if entry.place > 1 %}
                                    <div class="tournament-row">
                                        <div class="tournament-place tournament-place--{{ entry.place <= 3 ? entry.place : 'default' }}">
                                            {{ entry.place }}
                                        </div>

                                        {% if entry.commander_image %}
                                            <div class="w-9 h-9 rounded overflow-hidden flex-shrink-0">
                                                <img src="{{ entry.commander_image }}"
                                                     alt="{{ entry.commander_name }}"
                                                     class="w-full h-full object-cover"
                                                     loading="lazy">
                                            </div>
                                        {% else %}
                                            <div class="w-9 h-9 rounded bg-bg-tertiary flex-shrink-0"></div>
                                        {% endif %}

                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-text-primary truncate leading-tight">{{ entry.player_name }}</p>
                                            <p class="text-xs text-text-muted font-mono truncate leading-tight">{{ entry.commander_name }}</p>
                                        </div>

                                        {% if entry.score %}
                                            <span class="text-xs font-mono text-text-muted flex-shrink-0">{{ entry.score }}</span>
                                        {% endif %}

                                        {% if entry.decklist_url %}
                                            <a href="{{ entry.decklist_url }}"
                                               class="flex-shrink-0 px-2 py-0.5 bg-brand-orange/10 border border-brand-orange/20 rounded text-xs font-semibold text-brand-orange hover:bg-brand-orange/20 transition-colors">
                                                {{ __('Deck', 'pdc-theme') }}
                                            </a>
                                        {% else %}
                                            <span class="flex-shrink-0 text-xs text-text-muted/40">—</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>

                    {% else %}
                        <p class="text-text-muted italic text-sm">{{ __('Résultats non disponibles.', 'pdc-theme') }}</p>
                    {% endif %}
                </div>

                {# ===== Right: Meta sidebar (2 cols) ===== #}
                <div class="lg:col-span-2">
                    <h2 class="text-lg font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                        <span class="w-1 h-5 bg-brand-orange rounded-full"></span>
                        {{ __('Méta', 'pdc-theme') }}
                    </h2>

                    {% if has_meta %}

                        {# Compact color distribution #}
                        {% if color_counts %}
                            <div class="tournament-meta-panel mb-4">
                                <h3 class="text-xs font-heading font-semibold text-text-muted uppercase tracking-wider mb-3">
                                    {{ __('Couleurs', 'pdc-theme') }}
                                </h3>
                                <div class="flex flex-wrap gap-2">
                                    {% set color_labels = {'W': 'Blanc', 'U': 'Bleu', 'B': 'Noir', 'R': 'Rouge', 'G': 'Vert', 'C': 'Incolore'} %}
                                    {% for code, count in color_counts %}
                                        <div class="flex items-center gap-1.5 px-2.5 py-1 bg-bg-primary/60 rounded border border-white/5">
                                            {{ function('Deck_Renderer::format_color_symbol', code)|raw }}
                                            <span class="text-xs font-bold text-text-primary">{{ count }}</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# Commander distribution - compact bars #}
                        <div class="tournament-meta-panel">
                            <h3 class="text-xs font-heading font-semibold text-text-muted uppercase tracking-wider mb-3">
                                {{ __('Généraux joués', 'pdc-theme') }}
                            </h3>

                            <div class="space-y-2">
                                {% for commander in meta_commanders %}
                                    <div class="tournament-commander-row">
                                        {% if commander.image %}
                                            <div class="w-7 h-7 rounded overflow-hidden flex-shrink-0">
                                                <img src="{{ commander.image }}" alt="{{ commander.name }}"
                                                     class="w-full h-full object-cover" loading="lazy">
                                            </div>
                                        {% else %}
                                            <div class="w-7 h-7 rounded bg-bg-tertiary flex-shrink-0"></div>
                                        {% endif %}

                                        <div class="flex-1 min-w-0">
                                            <div class="flex items-baseline justify-between mb-0.5">
                                                <span class="text-xs font-mono text-text-primary truncate">{{ commander.name }}</span>
                                                <span class="flex-shrink-0 ml-2 text-xs text-text-muted tabular-nums">
                                                    {{ commander.count }}<span class="text-text-muted/50">/{{ player_count }}</span>
                                                    <span class="ml-1 text-magic-gold font-semibold">{{ commander.percentage }}%</span>
                                                </span>
                                            </div>
                                            <div class="h-1 bg-bg-primary rounded-full overflow-hidden">
                                                <div class="h-full bg-gradient-to-r from-brand-orange to-magic-gold rounded-full"
                                                     style="width: {{ commander.percentage }}%"></div>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                    {% else %}
                        <div class="tournament-meta-panel">
                            <p class="text-text-muted italic text-sm">{{ __('Données de méta non disponibles.', 'pdc-theme') }}</p>
                        </div>
                    {% endif %}
                </div>

            </div>{# /grid #}

        </div>
    </div>
</section>

{% endblock %}
