{#
/**
 * Single Tournament Template
 *
 * Variables:
 * - post (Timber\Post)
 * - date_formatted (string)
 * - location, city (string)
 * - player_count (int)
 * - signup_url (string)
 * - top8 (array): [{place, player_name, commander_name, score, commander_image, decklist_url}]
 * - meta_commanders (array): [{name, count, percentage, image, colors}]
 * - color_counts (array): {'W': n, ...}
 * - hero_image (string|null): art_crop of the winner's commander
 * - has_meta (bool)
 * - archive_url (string)
 */
#}

{% extends "layouts/base.twig" %}

{% block content %}

{# ---- Compact Hero ---- #}
<section class="tournament-hero relative overflow-hidden">
    {% if hero_image %}
        <div class="absolute inset-0 opacity-15">
            <img src="{{ hero_image }}" alt="" class="w-full h-full object-cover" aria-hidden="true">
        </div>
        <div class="absolute inset-0 bg-gradient-to-b from-bg-primary/70 via-bg-secondary/90 to-bg-primary"></div>
    {% else %}
        <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary"></div>
    {% endif %}

    <div class="container mx-auto px-4 sm:px-6 relative z-10 py-8 md:py-10">
        {# Back link + title row #}
        <div class="max-w-6xl mx-auto">
            <a href="{{ archive_url }}"
               class="inline-flex items-center gap-1.5 text-xs text-text-muted hover:text-brand-orange transition-colors mb-3 uppercase tracking-wider font-heading">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
                {{ __('Tournois', 'pdc-theme') }}
            </a>

            <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
                <h1 class="text-2xl md:text-3xl font-heading font-bold text-magic-gradient leading-tight">
                    {{ post.title }}
                </h1>

                {# Inline meta badges #}
                <div class="flex flex-wrap items-center gap-2 sm:flex-shrink-0">
                    {% if date_formatted %}
                        <span class="tournament-badge tournament-badge--primary">
                            <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                            </svg>
                            {{ date_formatted }}
                        </span>
                    {% endif %}
                    {% if location %}
                        <span class="tournament-badge">
                            <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            {{ location }}{% if city %}, {{ city }}{% endif %}
                        </span>
                    {% endif %}
                    {% if player_count %}
                        <span class="tournament-badge">
                            <svg class="w-3 h-3 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            {{ player_count }} {{ __('joueurs', 'pdc-theme') }}
                        </span>
                    {% endif %}
                    {% if signup_url %}
                        <a href="{{ signup_url }}" target="_blank" rel="noopener noreferrer"
                           class="tournament-badge hover:border-brand-orange/50 hover:text-brand-orange transition-colors">
                            {{ __('Inscription', 'pdc-theme') }}
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                            </svg>
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{# ---- Tournament details ---- #}
{% if details %}
<section class="py-6 md:py-8 bg-bg-secondary border-b border-magic-gold/10">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="max-w-6xl mx-auto">
            <div class="rich-text text-sm text-text-secondary">
                {{ details|raw }}
            </div>
            {% if signup_url %}
            <div class="mt-6">
                <a href="{{ signup_url }}" target="_blank" rel="noopener noreferrer"
                   class="btn-primary text-sm px-5 py-2">
                    {{ __("S'inscrire", 'pdc-theme') }}
                    <svg class="w-4 h-4 ml-1 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                </a>
            </div>
            {% endif %}
        </div>
    </div>
</section>
{% endif %}

{# ---- Main content: Top 8 + Meta (only for past tournaments) ---- #}
{% if is_past %}
<section class="py-6 md:py-8 bg-bg-primary">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="max-w-6xl mx-auto">

            <div class="grid lg:grid-cols-5 gap-6 items-start">

                {# ===== Left: Top 8 (3 cols) ===== #}
                <div class="lg:col-span-3 min-w-0">
                    {% set top_label = top8|length <= 4 ? 'Top 4' : 'Top 8' %}
                    <h2 class="text-lg font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                        <span class="w-1 h-5 bg-brand-orange rounded-full"></span>
                        {{ top_label }}
                    </h2>

                    {% if top8 %}
                        {# Winner highlight #}
                        {% set winner = top8|first %}
                        {% if winner and winner.place == 1 %}
                            {% if winner.decklist_url %}
                                <a href="{{ winner.decklist_url }}" class="tournament-winner tournament-winner--link mb-4 block {{ winner.is_banned ? 'opacity-70' : '' }}">
                            {% else %}
                                <div class="tournament-winner mb-4 {{ winner.is_banned ? 'opacity-70' : '' }}">
                            {% endif %}
                                <div class="flex items-center gap-2 sm:gap-3">
                                    <div class="tournament-place tournament-place--1">1</div>
                                    {% if winner.commander_image %}
                                        <div class="w-10 h-10 sm:w-14 sm:h-14 rounded-lg overflow-hidden shadow-lg ring-2 {{ winner.is_banned ? 'ring-red-500/40 grayscale' : 'ring-yellow-500/30' }} flex-shrink-0">
                                            <img src="{{ winner.commander_image }}"
                                                 alt="{{ winner.commander_name }}"
                                                 class="w-full h-full object-cover"
                                                 loading="lazy">
                                        </div>
                                    {% endif %}
                                    <div class="flex-1 min-w-0">
                                        {% set cmd_parts = winner.commander_name|split(' // ') %}
                                        <div class="flex items-center gap-1.5">
                                            <p class="font-bold text-sm sm:text-base text-yellow-300 font-beleren truncate leading-tight {{ winner.is_banned ? 'line-through decoration-red-500/70' : '' }}">{{ cmd_parts[0] }}</p>
                                            {% if winner.is_banned %}
                                                <span class="flex-shrink-0 px-1.5 py-0.5 bg-red-500/20 border border-red-500/30 rounded text-[10px] font-bold text-red-400 uppercase tracking-wider leading-none">
                                                    {{ __('Banned', 'pdc-theme') }}
                                                </span>
                                            {% endif %}
                                        </div>
                                        {% if cmd_parts|length > 1 %}
                                            <p class="text-yellow-200/40 font-beleren truncate leading-tight {{ winner.is_banned ? 'line-through decoration-red-500/70' : '' }}" style="font-size:10px">+ {{ cmd_parts[1] }}</p>
                                        {% endif %}
                                        <p class="text-xs text-yellow-200/60 truncate">{{ winner.player_name }}</p>
                                    </div>
                                    {% if winner.score %}
                                        <span class="text-xs font-mono text-yellow-400/70 flex-shrink-0">{{ winner.score }}</span>
                                    {% endif %}
                                    {% if winner.decklist_url %}
                                        <span class="flex-shrink-0 px-2.5 py-1 bg-yellow-500/15 border border-yellow-500/30 rounded text-xs font-bold text-yellow-400 uppercase tracking-wide">
                                            {{ __('Deck', 'pdc-theme') }}
                                        </span>
                                    {% endif %}
                                </div>
                            {% if winner.decklist_url %}
                                </a>
                            {% else %}
                                </div>
                            {% endif %}
                        {% endif %}

                        {# Remaining top 8 as compact rows — each row is a link if decklist exists #}
                        <div class="tournament-table">
                            {% for entry in top8 %}
                                {% if entry.place > 1 %}
                                    {% if entry.decklist_url %}
                                        <a href="{{ entry.decklist_url }}" class="tournament-row tournament-row--link {{ entry.is_banned ? 'opacity-60' : '' }}">
                                    {% else %}
                                        <div class="tournament-row {{ entry.is_banned ? 'opacity-60' : '' }}">
                                    {% endif %}
                                        <div class="tournament-place tournament-place--{{ entry.place <= 3 ? entry.place : 'default' }}">
                                            {{ entry.place }}
                                        </div>

                                        {% if entry.commander_image %}
                                            <div class="w-9 h-9 rounded overflow-hidden flex-shrink-0 {{ entry.is_banned ? 'grayscale ring-1 ring-red-500/40' : '' }}">
                                                <img src="{{ entry.commander_image }}"
                                                     alt="{{ entry.commander_name }}"
                                                     class="w-full h-full object-cover"
                                                     loading="lazy">
                                            </div>
                                        {% else %}
                                            <div class="w-9 h-9 rounded bg-bg-tertiary flex-shrink-0"></div>
                                        {% endif %}

                                        <div class="flex-1 min-w-0">
                                            {% set cmd_parts = entry.commander_name|split(' // ') %}
                                            <div class="flex items-center gap-1.5">
                                                <p class="text-sm font-semibold text-text-primary font-beleren truncate leading-tight {{ entry.is_banned ? 'line-through decoration-red-500/70' : '' }}">{{ cmd_parts[0] }}</p>
                                                {% if entry.is_banned %}
                                                    <span class="flex-shrink-0 px-1.5 py-0.5 bg-red-500/20 border border-red-500/30 rounded text-[10px] font-bold text-red-400 uppercase tracking-wider leading-none">
                                                        {{ __('Banned', 'pdc-theme') }}
                                                    </span>
                                                {% endif %}
                                            </div>
                                            {% if cmd_parts|length > 1 %}
                                                <p class="text-text-muted/60 font-beleren truncate leading-tight {{ entry.is_banned ? 'line-through decoration-red-500/70' : '' }}" style="font-size:10px">+ {{ cmd_parts[1] }}</p>
                                            {% endif %}
                                            <p class="text-xs text-text-muted truncate leading-tight">{{ entry.player_name }}</p>
                                        </div>

                                        {% if entry.score %}
                                            <span class="text-xs font-mono text-text-muted flex-shrink-0">{{ entry.score }}</span>
                                        {% endif %}

                                        {% if entry.decklist_url %}
                                            <span class="flex-shrink-0 px-2 py-0.5 bg-brand-orange/10 border border-brand-orange/20 rounded text-xs font-semibold text-brand-orange">
                                                {{ __('Deck', 'pdc-theme') }}
                                            </span>
                                        {% else %}
                                            <span class="flex-shrink-0 text-xs text-text-muted/40">—</span>
                                        {% endif %}

                                    {% if entry.decklist_url %}
                                        </a>
                                    {% else %}
                                        </div>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                        </div>

                    {% else %}
                        <p class="text-text-muted italic text-sm">{{ __('Résultats non disponibles.', 'pdc-theme') }}</p>
                    {% endif %}
                </div>

                {# ===== Right: Meta sidebar (2 cols) ===== #}
                <div class="lg:col-span-2 min-w-0 space-y-4">
                    <h2 class="text-lg sm:text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                        <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                        {{ __('Méta', 'pdc-theme') }}
                    </h2>

                    {% if has_meta %}

                        {# Commander distribution - compact bars #}
                        <div class="tournament-meta-panel !p-3 sm:!p-4">
                            <h3 class="text-sm font-heading font-semibold text-text-secondary uppercase tracking-wider mb-3">
                                {{ __('Généraux joués', 'pdc-theme') }}
                            </h3>

                            {% set max_pct = 0 %}
                            {% for commander in meta_commanders %}
                                {% if commander.percentage > max_pct %}
                                    {% set max_pct = commander.percentage %}
                                {% endif %}
                            {% endfor %}

                            <div class="space-y-3">
                                {% for commander in meta_commanders %}
                                    <div class="tournament-commander-row {{ commander.is_banned ? 'opacity-60' : '' }}">
                                        {% if commander.image %}
                                            <div class="w-11 h-11 sm:w-14 sm:h-14 rounded-lg overflow-hidden flex-shrink-0 ring-1 {{ commander.is_banned ? 'ring-red-500/40 grayscale' : 'ring-white/10' }}">
                                                <img src="{{ commander.image }}" alt="{{ commander.name }}"
                                                     class="w-full h-full object-cover" loading="lazy">
                                            </div>
                                        {% else %}
                                            <div class="w-11 h-11 sm:w-14 sm:h-14 rounded-lg bg-bg-tertiary flex-shrink-0"></div>
                                        {% endif %}

                                        <div class="flex-1 min-w-0">
                                            {% set cmd_parts = commander.name|split(' // ') %}
                                            <div class="flex items-center justify-between gap-1">
                                                <span class="text-xs sm:text-sm font-beleren text-text-primary truncate {{ commander.is_banned ? 'line-through decoration-red-500/70' : '' }}">{{ cmd_parts[0] }}</span>
                                                <div class="flex items-center gap-1.5 flex-shrink-0">
                                                    {% if commander.is_banned %}
                                                        <span class="px-1.5 py-0.5 bg-red-500/20 border border-red-500/30 rounded text-[10px] font-bold text-red-400 uppercase tracking-wider leading-none">
                                                            {{ __('Banned', 'pdc-theme') }}
                                                        </span>
                                                    {% endif %}
                                                    <span class="text-xs sm:text-sm text-text-secondary tabular-nums whitespace-nowrap">
                                                        {{ commander.count }}<span class="text-text-secondary/60">/{{ player_count }}</span>
                                                        <span class="ml-1 text-magic-gold font-semibold">{{ commander.percentage }}%</span>
                                                    </span>
                                                </div>
                                            </div>
                                            {% if cmd_parts|length > 1 %}
                                                <span class="font-beleren text-text-secondary/60 truncate block leading-tight {{ commander.is_banned ? 'line-through decoration-red-500/70' : '' }}" style="font-size:10px">+ {{ cmd_parts[1] }}</span>
                                            {% endif %}
                                            <div class="flex items-center gap-0.5 mt-0.5">
                                                {% if commander.colors|length > 0 %}
                                                    {% for color in commander.colors %}
                                                        <i class="ms ms-{{ color|lower }} ms-cost ms-shadow" title="{{ color }}"></i>
                                                    {% endfor %}
                                                {% else %}
                                                    <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                                {% endif %}
                                            </div>
                                        </div>

                                        {# Bar — hidden on mobile, visible sm+ #}
                                        <div class="hidden sm:block flex-shrink-0 w-20 h-2 bg-bg-primary/50 rounded-full overflow-hidden self-center">
                                            <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                                 style="width: {{ max_pct > 0 ? (commander.percentage / max_pct * 100)|round : 0 }}%"></div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        {# Color identity breakdown #}
                        {% if color_identity_counts %}
                            {% set ci_labels = {
                                'W': 'Mono Blanc',
                                'U': 'Mono Bleu',
                                'B': 'Mono Noir',
                                'R': 'Mono Rouge',
                                'G': 'Mono Vert',
                                'C': 'Incolore',
                                'BU': 'Dimir',
                                'BR': 'Rakdos',
                                'BG': 'Golgari',
                                'BW': 'Orzhov',
                                'GR': 'Gruul',
                                'GU': 'Simic',
                                'GW': 'Selesnya',
                                'RU': 'Izzet',
                                'RW': 'Boros',
                                'UW': 'Azorius',
                                'BGR': 'Jund',
                                'BGU': 'Sultai',
                                'BGW': 'Abzan',
                                'BRU': 'Grixis',
                                'BRW': 'Mardu',
                                'BUW': 'Esper',
                                'GRU': 'Temur',
                                'GRW': 'Naya',
                                'GUW': 'Bant',
                                'RUW': 'Jeskai',
                                'BGRU': 'Sans Blanc',
                                'BGRW': 'Sans Bleu',
                                'BGUW': 'Sans Rouge',
                                'BRUW': 'Sans Vert',
                                'GRUW': 'Sans Noir',
                                'BGRUW': '5 Couleurs'
                            } %}

                            {% set ci_total = 0 %}
                            {% for key, count in color_identity_counts %}
                                {% set ci_total = ci_total + count %}
                            {% endfor %}

                            {% set ci_max = 0 %}
                            {% for key, count in color_identity_counts %}
                                {% if count > ci_max %}
                                    {% set ci_max = count %}
                                {% endif %}
                            {% endfor %}

                            <div class="tournament-meta-panel !p-3 sm:!p-4">
                                <h3 class="text-sm font-heading font-semibold text-text-secondary uppercase tracking-wider mb-3">
                                    {{ __('Identités de couleur', 'pdc-theme') }}
                                </h3>

                                <div class="space-y-2">
                                    {% for identity_key, count in color_identity_counts %}
                                        {% set pct = (ci_total > 0) ? (count / ci_total * 100)|round : 0 %}
                                        {% set label = ci_labels[identity_key] ?? identity_key %}

                                        <div class="flex flex-col gap-1 sm:gap-1.5 py-1.5 {% if not loop.last %}border-b border-white/5{% endif %}">
                                            <div class="flex items-center justify-between gap-1">
                                                <div class="flex items-center gap-1.5 sm:gap-2 min-w-0">
                                                    <div class="flex items-center gap-0.5 flex-shrink-0">
                                                        {% if identity_key == 'C' %}
                                                            <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                                        {% else %}
                                                            {% for char in identity_key|split('') %}
                                                                <i class="ms ms-{{ char|lower }} ms-cost ms-shadow" title="{{ char }}"></i>
                                                            {% endfor %}
                                                        {% endif %}
                                                    </div>
                                                    <span class="text-xs sm:text-sm font-mono text-text-primary truncate">{{ label }}</span>
                                                </div>
                                                <span class="flex-shrink-0 text-xs sm:text-sm text-text-secondary tabular-nums whitespace-nowrap">
                                                    {{ count }}<span class="text-text-secondary/60">/{{ ci_total }}</span>
                                                    <span class="ml-1 text-magic-gold font-semibold">{{ pct }}%</span>
                                                </span>
                                            </div>
                                            <div class="w-full h-1.5 bg-bg-primary/50 rounded-full overflow-hidden">
                                                <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                                     style="width: {{ ci_max > 0 ? (count / ci_max * 100)|round : 0 }}%"></div>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endif %}

                        {# Color distribution as pie chart #}
                        {% if color_counts %}
                            <div class="tournament-meta-panel !p-3 sm:!p-4">
                                <h3 class="text-sm font-heading font-semibold text-text-secondary uppercase tracking-wider mb-3">
                                    {{ __('Répartition des couleurs', 'pdc-theme') }}
                                </h3>

                                {% set color_hex = {'W': '#F8F6F1', 'U': '#0E68AB', 'B': '#564D44', 'R': '#D3202A', 'G': '#00733E', 'C': '#BEB9B2'} %}
                                {% set color_labels = {'W': 'Blanc', 'U': 'Bleu', 'B': 'Noir', 'R': 'Rouge', 'G': 'Vert', 'C': 'Incolore'} %}

                                {% set color_total = 0 %}
                                {% for code, count in color_counts %}
                                    {% set color_total = color_total + count %}
                                {% endfor %}

                                <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
                                    {# SVG Pie chart #}
                                    {% set circ = 251.33 %}
                                    <div class="flex-shrink-0">
                                        <svg viewBox="0 0 100 100" class="w-28 h-28 sm:w-32 sm:h-32 tournament-pie">
                                            {% set cumulative = 0 %}
                                            {% for code, count in color_counts %}
                                                {% set pct = count / color_total * 100 %}
                                                {% set dash = pct / 100 * circ %}
                                                {% set gap = circ - dash %}
                                                {% set offset = circ / 4 - (cumulative / 100 * circ) %}
                                                <circle cx="50" cy="50" r="40"
                                                        fill="none"
                                                        stroke="{{ color_hex[code] ?? '#6B7280' }}"
                                                        stroke-width="18"
                                                        stroke-dasharray="{{ dash }} {{ gap }}"
                                                        stroke-dashoffset="{{ offset }}"
                                                        class="tournament-pie__slice"/>
                                                {% set cumulative = cumulative + pct %}
                                            {% endfor %}
                                        </svg>
                                    </div>

                                    {# Legend #}
                                    <div class="flex-1 w-full space-y-1.5">
                                        {% for code, count in color_counts %}
                                            <div class="flex items-center gap-2">
                                                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background: {{ color_hex[code] ?? '#6B7280' }};{% if code == 'B' %} border: 1px solid rgba(255,255,255,0.15);{% endif %}"></span>
                                                <span class="text-xs text-text-secondary">{{ color_labels[code] ?? code }}</span>
                                                <span class="text-xs font-bold text-text-primary ml-auto">{{ count }}</span>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                    {% else %}
                        <div class="tournament-meta-panel !p-3 sm:!p-4">
                            <p class="text-text-muted italic text-sm">{{ __('Données de méta non disponibles.', 'pdc-theme') }}</p>
                        </div>
                    {% endif %}
                </div>

            </div>{# /grid #}

        </div>
    </div>
</section>
{% endif %}

{% endblock %}
