{#
/**
 * Meta Page Template
 *
 * Variables:
 * - post (Timber\Post)
 * - global_meta (array): {commanders, color_counts, color_identity_counts, total_players, tournament_count, has_data}
 */
#}

{% extends "layouts/base.twig" %}

{% block content %}

{# ---- Shared macros ---- #}
{% set ci_labels = {
    'W': 'Mono Blanc',
    'U': 'Mono Bleu',
    'B': 'Mono Noir',
    'R': 'Mono Rouge',
    'G': 'Mono Vert',
    'C': 'Incolore',
    'BU': 'Dimir',
    'BR': 'Rakdos',
    'BG': 'Golgari',
    'BW': 'Orzhov',
    'GR': 'Gruul',
    'GU': 'Simic',
    'GW': 'Selesnya',
    'RU': 'Izzet',
    'RW': 'Boros',
    'UW': 'Azorius',
    'BGR': 'Jund',
    'BGU': 'Sultai',
    'BGW': 'Abzan',
    'BRU': 'Grixis',
    'BRW': 'Mardu',
    'BUW': 'Esper',
    'GRU': 'Temur',
    'GRW': 'Naya',
    'GUW': 'Bant',
    'RUW': 'Jeskai',
    'BGRU': 'Sans Blanc',
    'BGRW': 'Sans Bleu',
    'BGUW': 'Sans Rouge',
    'BRUW': 'Sans Vert',
    'GRUW': 'Sans Noir',
    'BGRUW': '5 Couleurs'
} %}

{% set color_hex = {'W': '#F8F6F1', 'U': '#0E68AB', 'B': '#564D44', 'R': '#D3202A', 'G': '#00733E', 'C': '#BEB9B2'} %}
{% set color_labels = {'W': 'Blanc', 'U': 'Bleu', 'B': 'Noir', 'R': 'Rouge', 'G': 'Vert', 'C': 'Incolore'} %}

{# ---- Hero ---- #}
<section class="py-16 bg-gradient-to-b from-bg-primary to-bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary"></div>
    <div class="absolute inset-0 opacity-10">
        <img src="{{ theme.link }}/public/cards-background.png"
             alt="" aria-hidden="true"
             class="w-full h-full object-cover">
    </div>
    <div class="container mx-auto px-4 sm:px-6 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-3xl sm:text-5xl md:text-6xl font-heading font-bold text-magic-gradient mb-6">
                {{ __('Méta PDC', 'pdc-theme') }}
            </h1>
            <p class="text-base sm:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
                {{ __('Analyse du métagame Pauper Duel Commander : généraux les plus joués, répartition des couleurs et tendances par tournoi.', 'pdc-theme') }}
            </p>
        </div>
    </div>
</section>

{# ================================================================ #}
{# ---- Global Meta ---- #}
{# ================================================================ #}
{% if global_meta.has_data %}
<section class="py-10 sm:py-16 bg-bg-secondary border-t border-magic-gold/10">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="max-w-5xl mx-auto">

            <div class="text-center mb-8 sm:mb-10">
                <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading font-bold text-magic-gradient mb-3">
                    {{ __('Méta Globale', 'pdc-theme') }}
                </h2>
                <p class="text-sm sm:text-base text-text-secondary">
                    {{ __('Statistiques agrégées sur', 'pdc-theme') }}
                    <span class="text-magic-gold font-semibold">{{ global_meta.tournament_count }}</span>
                    {{ __('tournois', 'pdc-theme') }}
                    &mdash;
                    <span class="text-magic-gold font-semibold">{{ global_meta.total_players }}</span>
                    {{ __('entrées joueurs', 'pdc-theme') }}
                </p>
            </div>

            <div class="grid lg:grid-cols-5 gap-6 lg:gap-8 items-start">

                {# ===== Left: Commander ranking (3 cols) ===== #}
                <div class="lg:col-span-3 min-w-0">
                    <h3 class="text-lg sm:text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                        <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                        {{ __('Généraux les plus joués', 'pdc-theme') }}
                    </h3>

                    <div class="tournament-meta-panel !p-3 sm:!p-4">
                        {% set max_pct = 0 %}
                        {% for commander in global_meta.commanders %}
                            {% if commander.percentage > max_pct %}
                                {% set max_pct = commander.percentage %}
                            {% endif %}
                        {% endfor %}

                        <div class="space-y-3">
                            {% for commander in global_meta.commanders %}
                                <div class="tournament-commander-row flex-wrap sm:flex-nowrap">
                                    {# Rank badge #}
                                    <div class="w-6 h-6 sm:w-7 sm:h-7 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold
                                        {% if loop.index == 1 %}
                                            bg-yellow-500/20 text-yellow-400 ring-1 ring-yellow-500/30
                                        {% elseif loop.index == 2 %}
                                            bg-gray-400/15 text-gray-300 ring-1 ring-gray-400/20
                                        {% elseif loop.index == 3 %}
                                            bg-amber-700/20 text-amber-500 ring-1 ring-amber-700/30
                                        {% else %}
                                            bg-bg-tertiary text-text-muted
                                        {% endif %}
                                    ">
                                        {{ loop.index }}
                                    </div>

                                    {% if commander.image %}
                                        <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg overflow-hidden flex-shrink-0 ring-1 ring-white/10">
                                            <img src="{{ commander.image }}" alt="{{ commander.name }}"
                                                 class="w-full h-full object-cover" loading="lazy">
                                        </div>
                                    {% else %}
                                        <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg bg-bg-tertiary flex-shrink-0"></div>
                                    {% endif %}

                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center justify-between gap-1">
                                            <span class="text-xs sm:text-sm font-mono text-text-primary truncate">{{ commander.name }}</span>
                                            <span class="flex-shrink-0 text-xs sm:text-sm text-text-secondary tabular-nums whitespace-nowrap">
                                                {{ commander.count }}<span class="text-text-secondary/60">/{{ global_meta.total_players }}</span>
                                                <span class="ml-1 text-magic-gold font-semibold">{{ commander.percentage }}%</span>
                                            </span>
                                        </div>
                                        <div class="flex items-center gap-0.5 mt-0.5">
                                            {% if commander.colors|length > 0 %}
                                                {% for color in commander.colors %}
                                                    <i class="ms ms-{{ color|lower }} ms-cost ms-shadow" title="{{ color }}"></i>
                                                {% endfor %}
                                            {% else %}
                                                <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {# Bar #}
                                    <div class="hidden sm:block flex-shrink-0 w-20 h-2 bg-bg-primary/50 rounded-full overflow-hidden self-center">
                                        <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                             style="width: {{ max_pct > 0 ? (commander.percentage / max_pct * 100)|round : 0 }}%"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# ===== Right: Color identity + Color distribution (2 cols) ===== #}
                <div class="lg:col-span-2 min-w-0 space-y-6 sm:space-y-8">

                    {# --- Color Identity Breakdown --- #}
                    {% if global_meta.color_identity_counts %}
                        {% set ci_total = 0 %}
                        {% for key, count in global_meta.color_identity_counts %}
                            {% set ci_total = ci_total + count %}
                        {% endfor %}

                        {% set ci_max = 0 %}
                        {% for key, count in global_meta.color_identity_counts %}
                            {% if count > ci_max %}
                                {% set ci_max = count %}
                            {% endif %}
                        {% endfor %}

                        <h3 class="text-lg sm:text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                            <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                            {{ __('Méta par identité de couleur', 'pdc-theme') }}
                        </h3>

                        <div class="tournament-meta-panel !p-3 sm:!p-4">
                            <div class="space-y-2">
                                {% for identity_key, count in global_meta.color_identity_counts %}
                                    {% set pct = (ci_total > 0) ? (count / ci_total * 100)|round : 0 %}
                                    {% set label = ci_labels[identity_key] ?? identity_key %}

                                    <div class="flex flex-col gap-1 sm:gap-1.5 py-1.5 {% if not loop.last %}border-b border-white/5{% endif %}">
                                        <div class="flex items-center justify-between gap-1">
                                            <div class="flex items-center gap-1.5 sm:gap-2 min-w-0">
                                                <div class="flex items-center gap-0.5 flex-shrink-0">
                                                    {% if identity_key == 'C' %}
                                                        <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                                    {% else %}
                                                        {% for char in identity_key|split('') %}
                                                            <i class="ms ms-{{ char|lower }} ms-cost ms-shadow" title="{{ char }}"></i>
                                                        {% endfor %}
                                                    {% endif %}
                                                </div>
                                                <span class="text-xs sm:text-sm font-mono text-text-primary truncate">{{ label }}</span>
                                            </div>
                                            <span class="flex-shrink-0 text-xs sm:text-sm text-text-secondary tabular-nums whitespace-nowrap">
                                                {{ count }}<span class="text-text-secondary/60">/{{ ci_total }}</span>
                                                <span class="ml-1 text-magic-gold font-semibold">{{ pct }}%</span>
                                            </span>
                                        </div>
                                        <div class="w-full h-1.5 bg-bg-primary/50 rounded-full overflow-hidden">
                                            <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                                 style="width: {{ ci_max > 0 ? (count / ci_max * 100)|round : 0 }}%"></div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {# --- Color distribution pie --- #}
                    {% if global_meta.color_counts %}
                        <h3 class="text-lg sm:text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                            <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                            {{ __('Répartition des couleurs', 'pdc-theme') }}
                        </h3>

                        <div class="tournament-meta-panel !p-3 sm:!p-4">
                            {% set color_total = 0 %}
                            {% for code, count in global_meta.color_counts %}
                                {% set color_total = color_total + count %}
                            {% endfor %}

                            <div class="flex flex-col items-center gap-4 sm:gap-6">
                                {# SVG Pie chart #}
                                {% set circ = 251.33 %}
                                <div class="flex-shrink-0">
                                    <svg viewBox="0 0 100 100" class="w-32 h-32 sm:w-40 sm:h-40 tournament-pie">
                                        {% set cumulative = 0 %}
                                        {% for code, count in global_meta.color_counts %}
                                            {% set pct = count / color_total * 100 %}
                                            {% set dash = pct / 100 * circ %}
                                            {% set gap = circ - dash %}
                                            {% set offset = circ / 4 - (cumulative / 100 * circ) %}
                                            <circle cx="50" cy="50" r="40"
                                                    fill="none"
                                                    stroke="{{ color_hex[code] ?? '#6B7280' }}"
                                                    stroke-width="18"
                                                    stroke-dasharray="{{ dash }} {{ gap }}"
                                                    stroke-dashoffset="{{ offset }}"
                                                    class="tournament-pie__slice"/>
                                            {% set cumulative = cumulative + pct %}
                                        {% endfor %}
                                    </svg>
                                </div>

                                {# Legend #}
                                <div class="w-full space-y-2">
                                    {% for code, count in global_meta.color_counts %}
                                        {% set pct = (color_total > 0) ? (count / color_total * 100)|round : 0 %}
                                        <div class="flex items-center gap-2">
                                            <span class="w-3 h-3 rounded-full flex-shrink-0" style="background: {{ color_hex[code] ?? '#6B7280' }};{% if code == 'B' %} border: 1px solid rgba(255,255,255,0.15);{% endif %}"></span>
                                            <span class="text-xs sm:text-sm text-text-secondary">{{ color_labels[code] ?? code }}</span>
                                            <span class="text-xs sm:text-sm font-bold text-text-primary ml-auto tabular-nums">{{ count }}</span>
                                            <span class="text-xs text-text-secondary tabular-nums w-8 sm:w-10 text-right">{{ pct }}%</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% endif %}

                </div>

            </div>{# /grid #}

        </div>
    </div>
</section>
{% endif %}

{# ================================================================ #}
{# ---- Top 4 Meta ---- #}
{# ================================================================ #}
{% if top4_meta.has_data %}
<section class="py-10 sm:py-16 bg-bg-primary border-t border-white/5">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="max-w-5xl mx-auto">

            <div class="text-center mb-8 sm:mb-10">
                <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading font-bold text-magic-gradient mb-3">
                    {{ __('Méta Top 4', 'pdc-theme') }}
                </h2>
                <p class="text-sm sm:text-base text-text-secondary">
                    {{ __('Généraux ayant atteint le top 4 sur', 'pdc-theme') }}
                    <span class="text-magic-gold font-semibold">{{ top4_meta.tournament_count }}</span>
                    {{ __('tournois', 'pdc-theme') }}
                    &mdash;
                    <span class="text-magic-gold font-semibold">{{ top4_meta.total }}</span>
                    {{ __('places en top 4', 'pdc-theme') }}
                </p>
            </div>

            <div class="grid lg:grid-cols-5 gap-6 lg:gap-8 items-start">

                {# ===== Left: Commander ranking (3 cols) ===== #}
                <div class="lg:col-span-3 min-w-0">
                    <h3 class="text-lg sm:text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                        <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                        {{ __('Généraux en Top 4', 'pdc-theme') }}
                    </h3>

                    <div class="tournament-meta-panel !p-3 sm:!p-4">
                        {% set max_pct = 0 %}
                        {% for commander in top4_meta.commanders %}
                            {% if commander.percentage > max_pct %}
                                {% set max_pct = commander.percentage %}
                            {% endif %}
                        {% endfor %}

                        <div class="space-y-3">
                            {% for commander in top4_meta.commanders %}
                                <div class="tournament-commander-row flex-wrap sm:flex-nowrap">
                                    {# Rank badge #}
                                    <div class="w-6 h-6 sm:w-7 sm:h-7 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold
                                        {% if loop.index == 1 %}
                                            bg-yellow-500/20 text-yellow-400 ring-1 ring-yellow-500/30
                                        {% elseif loop.index == 2 %}
                                            bg-gray-400/15 text-gray-300 ring-1 ring-gray-400/20
                                        {% elseif loop.index == 3 %}
                                            bg-amber-700/20 text-amber-500 ring-1 ring-amber-700/30
                                        {% else %}
                                            bg-bg-tertiary text-text-muted
                                        {% endif %}
                                    ">
                                        {{ loop.index }}
                                    </div>

                                    {% if commander.image %}
                                        <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg overflow-hidden flex-shrink-0 ring-1 ring-white/10">
                                            <img src="{{ commander.image }}" alt="{{ commander.name }}"
                                                 class="w-full h-full object-cover" loading="lazy">
                                        </div>
                                    {% else %}
                                        <div class="w-9 h-9 sm:w-11 sm:h-11 rounded-lg bg-bg-tertiary flex-shrink-0"></div>
                                    {% endif %}

                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center justify-between gap-1">
                                            <span class="text-xs sm:text-sm font-mono text-text-primary truncate">{{ commander.name }}</span>
                                            <span class="flex-shrink-0 text-xs sm:text-sm text-text-secondary tabular-nums whitespace-nowrap">
                                                {{ commander.count }}<span class="text-text-secondary/60">/{{ top4_meta.total }}</span>
                                                <span class="ml-1 text-magic-gold font-semibold">{{ commander.percentage }}%</span>
                                            </span>
                                        </div>
                                        <div class="flex items-center gap-0.5 mt-0.5">
                                            {% if commander.colors|length > 0 %}
                                                {% for color in commander.colors %}
                                                    <i class="ms ms-{{ color|lower }} ms-cost ms-shadow" title="{{ color }}"></i>
                                                {% endfor %}
                                            {% else %}
                                                <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {# Bar #}
                                    <div class="hidden sm:block flex-shrink-0 w-20 h-2 bg-bg-primary/50 rounded-full overflow-hidden self-center">
                                        <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                             style="width: {{ max_pct > 0 ? (commander.percentage / max_pct * 100)|round : 0 }}%"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# ===== Right: Color identity + Color distribution (2 cols) ===== #}
                <div class="lg:col-span-2 min-w-0 space-y-6 sm:space-y-8">

                    {# --- Color Identity Breakdown --- #}
                    {% if top4_meta.color_identity_counts %}
                        {% set ci_total = 0 %}
                        {% for key, count in top4_meta.color_identity_counts %}
                            {% set ci_total = ci_total + count %}
                        {% endfor %}

                        {% set ci_max = 0 %}
                        {% for key, count in top4_meta.color_identity_counts %}
                            {% if count > ci_max %}
                                {% set ci_max = count %}
                            {% endif %}
                        {% endfor %}

                        <h3 class="text-lg sm:text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                            <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                            {{ __('Identités de couleur en Top 4', 'pdc-theme') }}
                        </h3>

                        <div class="tournament-meta-panel !p-3 sm:!p-4">
                            <div class="space-y-2">
                                {% for identity_key, count in top4_meta.color_identity_counts %}
                                    {% set pct = (ci_total > 0) ? (count / ci_total * 100)|round : 0 %}
                                    {% set label = ci_labels[identity_key] ?? identity_key %}

                                    <div class="flex flex-col gap-1 sm:gap-1.5 py-1.5 {% if not loop.last %}border-b border-white/5{% endif %}">
                                        <div class="flex items-center justify-between gap-1">
                                            <div class="flex items-center gap-1.5 sm:gap-2 min-w-0">
                                                <div class="flex items-center gap-0.5 flex-shrink-0">
                                                    {% if identity_key == 'C' %}
                                                        <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                                    {% else %}
                                                        {% for char in identity_key|split('') %}
                                                            <i class="ms ms-{{ char|lower }} ms-cost ms-shadow" title="{{ char }}"></i>
                                                        {% endfor %}
                                                    {% endif %}
                                                </div>
                                                <span class="text-xs sm:text-sm font-mono text-text-primary truncate">{{ label }}</span>
                                            </div>
                                            <span class="flex-shrink-0 text-xs sm:text-sm text-text-secondary tabular-nums whitespace-nowrap">
                                                {{ count }}<span class="text-text-secondary/60">/{{ ci_total }}</span>
                                                <span class="ml-1 text-magic-gold font-semibold">{{ pct }}%</span>
                                            </span>
                                        </div>
                                        <div class="w-full h-1.5 bg-bg-primary/50 rounded-full overflow-hidden">
                                            <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                                 style="width: {{ ci_max > 0 ? (count / ci_max * 100)|round : 0 }}%"></div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {# --- Color distribution pie --- #}
                    {% if top4_meta.color_counts %}
                        <h3 class="text-lg sm:text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                            <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                            {{ __('Couleurs en Top 4', 'pdc-theme') }}
                        </h3>

                        <div class="tournament-meta-panel !p-3 sm:!p-4">
                            {% set color_total = 0 %}
                            {% for code, count in top4_meta.color_counts %}
                                {% set color_total = color_total + count %}
                            {% endfor %}

                            <div class="flex flex-col items-center gap-4 sm:gap-6">
                                {% set circ = 251.33 %}
                                <div class="flex-shrink-0">
                                    <svg viewBox="0 0 100 100" class="w-32 h-32 sm:w-40 sm:h-40 tournament-pie">
                                        {% set cumulative = 0 %}
                                        {% for code, count in top4_meta.color_counts %}
                                            {% set pct = count / color_total * 100 %}
                                            {% set dash = pct / 100 * circ %}
                                            {% set gap = circ - dash %}
                                            {% set offset = circ / 4 - (cumulative / 100 * circ) %}
                                            <circle cx="50" cy="50" r="40"
                                                    fill="none"
                                                    stroke="{{ color_hex[code] ?? '#6B7280' }}"
                                                    stroke-width="18"
                                                    stroke-dasharray="{{ dash }} {{ gap }}"
                                                    stroke-dashoffset="{{ offset }}"
                                                    class="tournament-pie__slice"/>
                                            {% set cumulative = cumulative + pct %}
                                        {% endfor %}
                                    </svg>
                                </div>

                                <div class="w-full space-y-2">
                                    {% for code, count in top4_meta.color_counts %}
                                        {% set pct = (color_total > 0) ? (count / color_total * 100)|round : 0 %}
                                        <div class="flex items-center gap-2">
                                            <span class="w-3 h-3 rounded-full flex-shrink-0" style="background: {{ color_hex[code] ?? '#6B7280' }};{% if code == 'B' %} border: 1px solid rgba(255,255,255,0.15);{% endif %}"></span>
                                            <span class="text-xs sm:text-sm text-text-secondary">{{ color_labels[code] ?? code }}</span>
                                            <span class="text-xs sm:text-sm font-bold text-text-primary ml-auto tabular-nums">{{ count }}</span>
                                            <span class="text-xs text-text-secondary tabular-nums w-8 sm:w-10 text-right">{{ pct }}%</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% endif %}

                </div>

            </div>{# /grid #}

        </div>
    </div>
</section>
{% endif %}

{# ---- Empty state ---- #}
{% if not global_meta.has_data %}
<section class="py-16 bg-bg-primary">
    <div class="container mx-auto px-4 sm:px-6">
        <div class="text-center py-16">
            <svg class="w-24 h-24 text-magic-gold/20 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            <h2 class="text-2xl font-heading font-bold text-magic-gradient mb-4">
                {{ __('Aucune donnée de méta disponible', 'pdc-theme') }}
            </h2>
            <p class="text-text-secondary">
                {{ __('Les statistiques du métagame seront disponibles après les premiers tournois.', 'pdc-theme') }}
            </p>
        </div>
    </div>
</section>
{% endif %}

{% endblock %}
