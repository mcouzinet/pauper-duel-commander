{#
/**
 * Archive Tournament Template
 *
 * Variables:
 * - tournaments (array): Enriched tournament list, sorted by date DESC
 *   Each entry:
 *   - post, title, link, date_formatted, location, city, player_count, signup_url
 *   - top8 (array): [{place, player_name, commander_name, score, commander_image, decklist_url}]
 *   - meta_commanders (array): [{name, count, percentage, image}]
 *   - color_counts (array): {'W': n, 'U': n, ...}
 *   - has_meta (bool)
 */
#}

{% extends "layouts/base.twig" %}

{% block content %}

{# ---- Hero ---- #}
<section class="py-16 bg-gradient-to-b from-bg-primary to-bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary"></div>
    <div class="absolute inset-0 opacity-10">
        <img src="{{ theme.link }}/public/cards-background.png"
             alt="" aria-hidden="true"
             class="w-full h-full object-cover">
    </div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-5xl md:text-6xl font-heading font-bold text-magic-gradient mb-6">
                {{ __('Tournois PDC', 'pdc-theme') }}
            </h1>
            <p class="text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
                {{ __('Inscrivez-vous aux prochains tournois et retrouvez les résultats, top 8 et méta des événements passés.', 'pdc-theme') }}
            </p>
        </div>
    </div>
</section>

{# ---- Upcoming tournaments ---- #}
{% if upcoming_tournaments %}
<section class="py-16 bg-bg-primary border-b border-magic-gold/10">
    <div class="container mx-auto px-6">
        <div class="max-w-5xl mx-auto">

            <div class="flex items-center gap-3 mb-8">
                <span class="relative flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-orange opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-brand-orange"></span>
                </span>
                <h2 class="text-3xl font-heading font-bold text-magic-gradient">
                    {{ __('Prochains Tournois', 'pdc-theme') }}
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                {% for t in upcoming_tournaments %}
                <div class="magic-card p-6 relative overflow-hidden group">
                    {# Glow accent #}
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-orange via-magic-gold to-brand-orange"></div>

                    {# Date badge #}
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <h3 class="text-xl font-heading font-bold text-text-primary group-hover:text-magic-gold transition-colors">
                                {{ t.title }}
                            </h3>
                        </div>
                        {% if t.date_formatted %}
                        <span class="flex-shrink-0 ml-3 px-3 py-1 bg-brand-orange/10 border border-brand-orange/30 rounded-lg text-sm font-semibold text-brand-orange whitespace-nowrap">
                            {{ t.date_formatted }}
                        </span>
                        {% endif %}
                    </div>

                    {# Info #}
                    <div class="space-y-2 text-sm text-text-secondary mb-5">
                        {% if t.location %}
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-magic-gold/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span>{{ t.location }}{% if t.city %}, {{ t.city }}{% endif %}</span>
                        </div>
                        {% endif %}
                        {% if t.player_count %}
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-magic-gold/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span>{{ t.player_count }} {{ __('joueurs', 'pdc-theme') }}</span>
                        </div>
                        {% endif %}
                    </div>

                    {# Actions #}
                    <div class="flex flex-wrap items-center gap-3">
                        {% if t.signup_url %}
                        <a href="{{ t.signup_url }}" target="_blank" rel="noopener noreferrer"
                           class="btn-primary text-sm px-5 py-2">
                            {{ __("S'inscrire", 'pdc-theme') }}
                            <svg class="w-4 h-4 ml-1 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                            </svg>
                        </a>
                        {% endif %}
                        <a href="{{ t.link }}"
                           class="inline-flex items-center gap-2 text-sm font-semibold text-brand-orange hover:text-magic-gold transition-colors">
                            {{ __('Détails', 'pdc-theme') }}
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                            </svg>
                        </a>
                    </div>
                </div>
                {% endfor %}
            </div>

        </div>
    </div>
</section>
{% endif %}

{# ---- Past tournament results ---- #}
<section class="py-16 bg-bg-primary">
    <div class="container mx-auto px-6">
        <div class="max-w-5xl mx-auto">

            {% if past_tournaments %}

                <h2 class="text-3xl font-heading font-bold text-text-primary mb-8">
                    {{ __('Résultats des Tournois', 'pdc-theme') }}
                </h2>

                <div class="accordion space-y-4" data-accordion-group>

                    {% for t in past_tournaments %}
                    <div class="accordion-item magic-card overflow-hidden transition-all duration-300"
                         data-accordion-item>

                        {# ---- Accordion trigger ---- #}
                        <button class="accordion-trigger w-full text-left p-6 flex items-center gap-4 group"
                                data-accordion-trigger
                                aria-expanded="false"
                                aria-controls="tournament-content-{{ loop.index0 }}"
                                id="tournament-trigger-{{ loop.index0 }}">

                            {# Title + meta info #}
                            <span class="flex-1 min-w-0">
                                <span class="block text-xl font-heading font-bold text-text-primary group-hover:text-magic-gold transition-colors truncate">
                                    {{ t.title }}
                                </span>
                                <span class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-text-muted mt-1">
                                    {% if t.date_formatted %}
                                        <span>{{ t.date_formatted }}</span>
                                    {% endif %}
                                    {% if t.location %}
                                        <span class="hidden sm:inline text-text-muted/40">|</span>
                                        <span>{{ t.location }}{% if t.city %}, {{ t.city }}{% endif %}</span>
                                    {% endif %}
                                    {% if t.player_count %}
                                        <span class="hidden sm:inline text-text-muted/40">|</span>
                                        <span>{{ t.player_count }} {{ __('joueurs', 'pdc-theme') }}</span>
                                    {% endif %}
                                </span>
                            </span>

                            {# Chevron #}
                            <div class="accordion-icon flex-shrink-0 w-6 h-6 text-magic-gold transition-transform duration-300"
                                 data-accordion-icon aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
                                </svg>
                            </div>
                        </button>

                        {# ---- Accordion content ---- #}
                        <div class="accordion-content overflow-hidden"
                             data-accordion-content
                             id="tournament-content-{{ loop.index0 }}"
                             aria-labelledby="tournament-trigger-{{ loop.index0 }}"
                             role="region"
                             style="max-height: 0;">
                            <div class="accordion-inner px-6 pb-8 pt-2">

                                <div class="grid lg:grid-cols-2 gap-8">

                                    {# ---- Top 8 ---- #}
                                    <div>
                                        <h3 class="text-lg font-heading font-bold text-text-primary mb-4">
                                            {{ __('Top 8', 'pdc-theme') }}
                                        </h3>

                                        {% if t.top8 %}
                                            <div class="space-y-2">
                                                {% for entry in t.top8 %}
                                                    <div class="flex items-center gap-3 p-3 bg-bg-secondary/50 rounded-lg border border-magic-gold/5 hover:border-magic-gold/20 transition-colors">

                                                        {# Place badge #}
                                                        <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full text-xs font-bold
                                                            {% if entry.place == 1 %}bg-yellow-500/20 text-yellow-400 border border-yellow-500/30
                                                            {% elseif entry.place == 2 %}bg-slate-400/20 text-slate-300 border border-slate-400/30
                                                            {% elseif entry.place == 3 %}bg-amber-700/20 text-amber-500 border border-amber-700/30
                                                            {% else %}bg-bg-primary text-text-muted border border-magic-gold/10{% endif %}">
                                                            {{ entry.place }}
                                                        </span>

                                                        {# Commander art_crop thumbnail #}
                                                        {% if entry.commander_image %}
                                                            <div class="flex-shrink-0 w-10 h-10 rounded-lg overflow-hidden bg-bg-primary">
                                                                <img src="{{ entry.commander_image }}"
                                                                     alt="{{ entry.commander_name }}"
                                                                     class="w-full h-full object-cover"
                                                                     loading="lazy">
                                                            </div>
                                                        {% else %}
                                                            <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-bg-primary border border-magic-gold/10 flex items-center justify-center">
                                                                <svg class="w-5 h-5 text-magic-gold/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                                                </svg>
                                                            </div>
                                                        {% endif %}

                                                        {# Player + commander #}
                                                        <div class="flex-1 min-w-0">
                                                            <p class="text-sm font-semibold text-text-primary truncate">{{ entry.player_name }}</p>
                                                            <p class="text-xs text-text-muted truncate font-mono">{{ entry.commander_name }}</p>
                                                        </div>

                                                        {# Score + decklist link #}
                                                        <div class="flex-shrink-0 flex items-center gap-2">
                                                            {% if entry.score %}
                                                                <span class="text-xs text-text-secondary font-mono">{{ entry.score }}</span>
                                                            {% endif %}
                                                            {% if entry.decklist_url %}
                                                                <a href="{{ entry.decklist_url }}"
                                                                   class="text-xs px-2 py-0.5 bg-brand-orange/10 border border-brand-orange/30 rounded text-brand-orange hover:bg-brand-orange/20 transition-colors whitespace-nowrap"
                                                                   title="{{ __('Voir la decklist', 'pdc-theme') }}">
                                                                    {{ __('Decklist', 'pdc-theme') }}
                                                                </a>
                                                            {% endif %}
                                                        </div>

                                                    </div>
                                                {% endfor %}
                                            </div>
                                        {% else %}
                                            <p class="text-sm text-text-muted italic">{{ __('Résultats non disponibles.', 'pdc-theme') }}</p>
                                        {% endif %}
                                    </div>

                                    {# ---- Meta ---- #}
                                    <div>
                                        <h3 class="text-lg font-heading font-bold text-text-primary mb-4">
                                            {{ __('Méta du tournoi', 'pdc-theme') }}
                                        </h3>

                                        {% if t.has_meta %}

                                            {# Color distribution #}
                                            {% if t.color_counts %}
                                                <div class="flex flex-wrap gap-2 mb-5">
                                                    {% for code, count in t.color_counts %}
                                                        <span class="flex items-center gap-1.5 px-2 py-1 bg-bg-secondary rounded-lg border border-magic-gold/10 text-xs text-text-secondary">
                                                            {{ function('Deck_Renderer::format_color_symbol', code)|raw }}
                                                            <span class="font-semibold text-text-primary">{{ count }}</span>
                                                        </span>
                                                    {% endfor %}
                                                </div>
                                            {% endif %}

                                            {# Commander bars #}
                                            <div class="space-y-2">
                                                {% for commander in t.meta_commanders|slice(0, 10) %}
                                                    <div class="flex items-center gap-3">
                                                        {% if commander.image %}
                                                            <div class="flex-shrink-0 w-8 h-8 rounded overflow-hidden bg-bg-primary">
                                                                <img src="{{ commander.image }}" alt="{{ commander.name }}"
                                                                     class="w-full h-full object-cover" loading="lazy">
                                                            </div>
                                                        {% endif %}
                                                        <div class="flex-1 min-w-0">
                                                            <div class="flex items-center justify-between mb-0.5">
                                                                <span class="text-xs font-mono text-text-secondary truncate">{{ commander.name }}</span>
                                                                <span class="flex-shrink-0 ml-2 text-xs text-text-muted">
                                                                    {{ commander.count }}× ({{ commander.percentage }}%)
                                                                </span>
                                                            </div>
                                                            <div class="h-1.5 bg-bg-primary rounded-full overflow-hidden">
                                                                <div class="h-full bg-gradient-to-r from-brand-orange to-magic-gold rounded-full"
                                                                     style="width: {{ commander.percentage }}%"></div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                                {% if t.meta_commanders|length > 10 %}
                                                    <p class="text-xs text-text-muted italic pt-1">
                                                        {{ __('… et', 'pdc-theme') }} {{ t.meta_commanders|length - 10 }} {{ __('autres généraux', 'pdc-theme') }}.
                                                        <a href="{{ t.link }}" class="text-brand-orange hover:underline">{{ __('Voir tout', 'pdc-theme') }}</a>
                                                    </p>
                                                {% endif %}
                                            </div>

                                        {% else %}
                                            <p class="text-sm text-text-muted italic">{{ __('Données de méta non disponibles pour ce tournoi.', 'pdc-theme') }}</p>
                                        {% endif %}
                                    </div>

                                </div>{# /grid #}

                                {# Link to full page + optional signup #}
                                <div class="flex flex-wrap items-center gap-3 mt-6 pt-6 border-t border-magic-gold/10">
                                    <a href="{{ t.link }}"
                                       class="inline-flex items-center gap-2 text-sm font-semibold text-brand-orange hover:text-magic-gold transition-colors">
                                        {{ __('Voir la page complète', 'pdc-theme') }}
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                                        </svg>
                                    </a>
                                    {% if t.signup_url %}
                                        <a href="{{ t.signup_url }}" target="_blank" rel="noopener noreferrer"
                                           class="inline-flex items-center gap-2 text-sm font-semibold text-text-secondary hover:text-text-primary border border-magic-gold/20 hover:border-magic-gold/40 px-3 py-1 rounded-lg transition-colors">
                                            {{ __("Lien d'inscription", 'pdc-theme') }}
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                                            </svg>
                                        </a>
                                    {% endif %}
                                </div>

                            </div>{# /accordion-inner #}
                        </div>{# /accordion-content #}

                    </div>{# /accordion-item #}
                    {% endfor %}

                </div>{# /accordion #}

            {% else %}

                {% if not upcoming_tournaments %}
                <div class="text-center py-16">
                    <svg class="w-24 h-24 text-magic-gold/20 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                    </svg>
                    <h2 class="text-2xl font-heading font-bold text-magic-gradient mb-4">
                        {{ __('Aucun tournoi pour le moment', 'pdc-theme') }}
                    </h2>
                    <p class="text-text-secondary">
                        {{ __('Les résultats des prochains tournois seront publiés ici.', 'pdc-theme') }}
                    </p>
                </div>
                {% else %}
                <p class="text-center text-text-muted py-8">
                    {{ __('Aucun résultat de tournoi disponible pour le moment.', 'pdc-theme') }}
                </p>
                {% endif %}

            {% endif %}

        </div>
    </div>
</section>

{% endblock %}
