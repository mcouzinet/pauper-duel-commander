{#
/**
 * Archive Tournament Template
 *
 * Variables:
 * - tournaments (array): Enriched tournament list, sorted by date DESC
 *   Each entry:
 *   - post, title, link, date_formatted, location, city, player_count, signup_url
 *   - top8 (array): [{place, player_name, commander_name, score, commander_image, decklist_url}]
 *   - meta_commanders (array): [{name, count, percentage, image, colors}]
 *   - color_counts (array): {'W': n, 'U': n, ...}
 *   - has_meta (bool)
 */
#}

{% extends "layouts/base.twig" %}

{% block content %}

{# ---- Hero ---- #}
<section class="py-16 bg-gradient-to-b from-bg-primary to-bg-secondary relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-bg-primary via-bg-secondary to-bg-primary"></div>
    <div class="absolute inset-0 opacity-10">
        <img src="{{ theme.link }}/public/cards-background.png"
             alt="" aria-hidden="true"
             class="w-full h-full object-cover">
    </div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-5xl md:text-6xl font-heading font-bold text-magic-gradient mb-6">
                {{ __('Tournois PDC', 'pdc-theme') }}
            </h1>
            <p class="text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
                {{ __('Inscrivez-vous aux prochains tournois et retrouvez les résultats, top 8 et méta des événements passés.', 'pdc-theme') }}
            </p>
        </div>
    </div>
</section>

{# ---- Upcoming tournaments ---- #}
{% if upcoming_tournaments %}
<section class="py-16 bg-bg-primary border-b border-magic-gold/10">
    <div class="container mx-auto px-6">
        <div class="max-w-5xl mx-auto">

            <div class="flex items-center gap-3 mb-8">
                <span class="relative flex h-3 w-3">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-orange opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-3 w-3 bg-brand-orange"></span>
                </span>
                <h2 class="text-3xl font-heading font-bold text-magic-gradient">
                    {{ __('Prochains Tournois', 'pdc-theme') }}
                </h2>
            </div>

            <div class="grid md:grid-cols-2 gap-6">
                {% for t in upcoming_tournaments %}
                <div class="magic-card p-6 relative overflow-hidden group">
                    {# Glow accent #}
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-brand-orange via-magic-gold to-brand-orange"></div>

                    {# Date badge #}
                    <div class="flex items-start justify-between mb-4">
                        <div>
                            <h3 class="text-xl font-heading font-bold text-text-primary group-hover:text-magic-gold transition-colors">
                                {{ t.title }}
                            </h3>
                        </div>
                        {% if t.date_formatted %}
                        <span class="flex-shrink-0 ml-3 px-3 py-1 bg-brand-orange/10 border border-brand-orange/30 rounded-lg text-sm font-semibold text-brand-orange whitespace-nowrap">
                            {{ t.date_formatted }}
                        </span>
                        {% endif %}
                    </div>

                    {# Info #}
                    <div class="space-y-2 text-sm text-text-secondary mb-5">
                        {% if t.location %}
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-magic-gold/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span>{{ t.location }}{% if t.city %}, {{ t.city }}{% endif %}</span>
                        </div>
                        {% endif %}
                        {% if t.player_count %}
                        <div class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-magic-gold/60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            <span>{{ t.player_count }} {{ __('joueurs', 'pdc-theme') }}</span>
                        </div>
                        {% endif %}
                    </div>

                    {# Actions #}
                    <div class="flex flex-wrap items-center gap-3">
                        {% if t.signup_url %}
                        <a href="{{ t.signup_url }}" target="_blank" rel="noopener noreferrer"
                           class="btn-primary text-sm px-5 py-2">
                            {{ __("S'inscrire", 'pdc-theme') }}
                            <svg class="w-4 h-4 ml-1 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                            </svg>
                        </a>
                        {% endif %}
                        <a href="{{ t.link }}"
                           class="inline-flex items-center gap-2 text-sm font-semibold text-brand-orange hover:text-magic-gold transition-colors">
                            {{ __('Détails', 'pdc-theme') }}
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                            </svg>
                        </a>
                    </div>
                </div>
                {% endfor %}
            </div>

        </div>
    </div>
</section>
{% endif %}

{# ---- Past tournament results ---- #}
<section class="py-16 bg-bg-primary">
    <div class="container mx-auto px-6">
        <div class="max-w-5xl mx-auto">

            {% if past_tournaments %}

                <h2 class="text-3xl font-heading font-bold text-text-primary mb-8">
                    {{ __('Résultats des Tournois', 'pdc-theme') }}
                </h2>

                <div class="space-y-4">

                    {% for t in past_tournaments %}
                    <a href="{{ t.link }}"
                       class="magic-card block p-6 group transition-all duration-300 hover:border-magic-gold/40">

                        <div class="flex items-center gap-4">
                            {# Title + meta info #}
                            <span class="flex-1 min-w-0">
                                <span class="block text-xl font-heading font-bold text-text-primary group-hover:text-magic-gold transition-colors truncate">
                                    {{ t.title }}
                                </span>
                                <span class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-text-muted mt-1">
                                    {% if t.date_formatted %}
                                        <span>{{ t.date_formatted }}</span>
                                    {% endif %}
                                    {% if t.location %}
                                        <span class="hidden sm:inline text-text-muted/40">|</span>
                                        <span>{{ t.location }}{% if t.city %}, {{ t.city }}{% endif %}</span>
                                    {% endif %}
                                    {% if t.player_count %}
                                        <span class="hidden sm:inline text-text-muted/40">|</span>
                                        <span>{{ t.player_count }} {{ __('joueurs', 'pdc-theme') }}</span>
                                    {% endif %}
                                </span>
                            </span>

                            {# Arrow #}
                            <div class="flex-shrink-0 w-6 h-6 text-magic-gold group-hover:translate-x-1 transition-transform duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-6 h-6">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                                </svg>
                            </div>
                        </div>

                    </a>
                    {% endfor %}

                </div>

            {% else %}

                {% if not upcoming_tournaments %}
                <div class="text-center py-16">
                    <svg class="w-24 h-24 text-magic-gold/20 mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
                    </svg>
                    <h2 class="text-2xl font-heading font-bold text-magic-gradient mb-4">
                        {{ __('Aucun tournoi pour le moment', 'pdc-theme') }}
                    </h2>
                    <p class="text-text-secondary">
                        {{ __('Les résultats des prochains tournois seront publiés ici.', 'pdc-theme') }}
                    </p>
                </div>
                {% else %}
                <p class="text-center text-text-muted py-8">
                    {{ __('Aucun résultat de tournoi disponible pour le moment.', 'pdc-theme') }}
                </p>
                {% endif %}

            {% endif %}

        </div>
    </div>
</section>

{# ---- Global Meta ---- #}
{% if global_meta.has_data %}
<section class="py-16 bg-bg-secondary border-t border-magic-gold/10">
    <div class="container mx-auto px-6">
        <div class="max-w-5xl mx-auto">

            <div class="text-center mb-10">
                <h2 class="text-3xl md:text-4xl font-heading font-bold text-magic-gradient mb-3">
                    {{ __('Méta Globale', 'pdc-theme') }}
                </h2>
                <p class="text-text-secondary">
                    {{ __('Statistiques agrégées sur', 'pdc-theme') }}
                    <span class="text-magic-gold font-semibold">{{ global_meta.tournament_count }}</span>
                    {{ __('tournois', 'pdc-theme') }}
                    &mdash;
                    <span class="text-magic-gold font-semibold">{{ global_meta.total_players }}</span>
                    {{ __('entrées joueurs', 'pdc-theme') }}
                </p>
            </div>

            <div class="grid lg:grid-cols-5 gap-8 items-start">

                {# ===== Left: Commander ranking (3 cols) ===== #}
                <div class="lg:col-span-3">
                    <h3 class="text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                        <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                        {{ __('Généraux les plus joués', 'pdc-theme') }}
                    </h3>

                    <div class="tournament-meta-panel">
                        {# Calculate max percentage for bar normalization #}
                        {% set max_pct = 0 %}
                        {% for commander in global_meta.commanders %}
                            {% if commander.percentage > max_pct %}
                                {% set max_pct = commander.percentage %}
                            {% endif %}
                        {% endfor %}

                        <div class="space-y-3">
                            {% for commander in global_meta.commanders %}
                                <div class="tournament-commander-row">
                                    {# Rank badge #}
                                    <div class="w-7 h-7 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-bold
                                        {% if loop.index == 1 %}
                                            bg-yellow-500/20 text-yellow-400 ring-1 ring-yellow-500/30
                                        {% elseif loop.index == 2 %}
                                            bg-gray-400/15 text-gray-300 ring-1 ring-gray-400/20
                                        {% elseif loop.index == 3 %}
                                            bg-amber-700/20 text-amber-500 ring-1 ring-amber-700/30
                                        {% else %}
                                            bg-bg-tertiary text-text-muted
                                        {% endif %}
                                    ">
                                        {{ loop.index }}
                                    </div>

                                    {% if commander.image %}
                                        <div class="w-11 h-11 rounded-lg overflow-hidden flex-shrink-0 ring-1 ring-white/10">
                                            <img src="{{ commander.image }}" alt="{{ commander.name }}"
                                                 class="w-full h-full object-cover" loading="lazy">
                                        </div>
                                    {% else %}
                                        <div class="w-11 h-11 rounded-lg bg-bg-tertiary flex-shrink-0"></div>
                                    {% endif %}

                                    <div class="flex-1 min-w-0">
                                        <div class="flex items-center justify-between">
                                            <span class="text-sm font-mono text-text-primary truncate">{{ commander.name }}</span>
                                            <span class="flex-shrink-0 ml-2 text-sm text-text-secondary tabular-nums">
                                                {{ commander.count }}<span class="text-text-secondary/60">/{{ global_meta.total_players }}</span>
                                                <span class="ml-1 text-magic-gold font-semibold">{{ commander.percentage }}%</span>
                                            </span>
                                        </div>
                                        <div class="flex items-center gap-0.5 mt-0.5">
                                            {% if commander.colors|length > 0 %}
                                                {% for color in commander.colors %}
                                                    <i class="ms ms-{{ color|lower }} ms-cost ms-shadow" title="{{ color }}"></i>
                                                {% endfor %}
                                            {% else %}
                                                <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {# Bar — fixed width, normalized to max #}
                                    <div class="flex-shrink-0 w-20 h-2 bg-bg-primary/50 rounded-full overflow-hidden self-center">
                                        <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                             style="width: {{ max_pct > 0 ? (commander.percentage / max_pct * 100)|round : 0 }}%"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                {# ===== Right: Color identity + Color distribution (2 cols) ===== #}
                <div class="lg:col-span-2 space-y-8">

                    {# --- Color Identity Breakdown --- #}
                    {% if global_meta.color_identity_counts %}
                        {% set ci_labels = {
                            'W': 'Mono Blanc',
                            'U': 'Mono Bleu',
                            'B': 'Mono Noir',
                            'R': 'Mono Rouge',
                            'G': 'Mono Vert',
                            'C': 'Incolore',
                            'BU': 'Dimir',
                            'BR': 'Rakdos',
                            'BG': 'Golgari',
                            'BW': 'Orzhov',
                            'GR': 'Gruul',
                            'GU': 'Simic',
                            'GW': 'Selesnya',
                            'RU': 'Izzet',
                            'RW': 'Boros',
                            'UW': 'Azorius',
                            'BGR': 'Jund',
                            'BGU': 'Sultai',
                            'BGW': 'Abzan',
                            'BRU': 'Grixis',
                            'BRW': 'Mardu',
                            'BUW': 'Esper',
                            'GRU': 'Temur',
                            'GRW': 'Naya',
                            'GUW': 'Bant',
                            'RUW': 'Jeskai',
                            'BGRU': 'Sans Blanc',
                            'BGRW': 'Sans Bleu',
                            'BGUW': 'Sans Rouge',
                            'BRUW': 'Sans Vert',
                            'GRUW': 'Sans Noir',
                            'BGRUW': '5 Couleurs'
                        } %}

                        {% set ci_total = 0 %}
                        {% for key, count in global_meta.color_identity_counts %}
                            {% set ci_total = ci_total + count %}
                        {% endfor %}

                        {% set ci_max = 0 %}
                        {% for key, count in global_meta.color_identity_counts %}
                            {% if count > ci_max %}
                                {% set ci_max = count %}
                            {% endif %}
                        {% endfor %}

                        <h3 class="text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                            <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                            {{ __('Méta par identité de couleur', 'pdc-theme') }}
                        </h3>

                        <div class="tournament-meta-panel">
                            <div class="space-y-2">
                                {% for identity_key, count in global_meta.color_identity_counts %}
                                    {% set pct = (ci_total > 0) ? (count / ci_total * 100)|round : 0 %}
                                    {% set label = ci_labels[identity_key] ?? identity_key %}

                                    <div class="flex flex-col gap-1.5 py-1.5 {% if not loop.last %}border-b border-white/5{% endif %}">
                                        {# Row 1: pips + label + stats #}
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-2 min-w-0">
                                                <div class="flex items-center gap-0.5 flex-shrink-0">
                                                    {% if identity_key == 'C' %}
                                                        <i class="ms ms-c ms-cost ms-shadow" title="C"></i>
                                                    {% else %}
                                                        {% for char in identity_key|split('') %}
                                                            <i class="ms ms-{{ char|lower }} ms-cost ms-shadow" title="{{ char }}"></i>
                                                        {% endfor %}
                                                    {% endif %}
                                                </div>
                                                <span class="text-sm font-mono text-text-primary truncate">{{ label }}</span>
                                            </div>
                                            <span class="flex-shrink-0 ml-2 text-sm text-text-secondary tabular-nums">
                                                {{ count }}<span class="text-text-secondary/60">/{{ ci_total }}</span>
                                                <span class="ml-1 text-magic-gold font-semibold">{{ pct }}%</span>
                                            </span>
                                        </div>
                                        {# Row 2: full-width bar #}
                                        <div class="w-full h-1.5 bg-bg-primary/50 rounded-full overflow-hidden">
                                            <div class="h-full rounded-full bg-gradient-to-r from-brand-orange to-magic-gold"
                                                 style="width: {{ ci_max > 0 ? (count / ci_max * 100)|round : 0 }}%"></div>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    {# --- Color distribution pie --- #}
                    {% if global_meta.color_counts %}
                        <h3 class="text-xl md:text-2xl font-heading font-bold text-text-primary uppercase tracking-wide mb-4 flex items-center gap-2">
                            <span class="w-1 h-6 bg-brand-orange rounded-full"></span>
                            {{ __('Répartition des couleurs', 'pdc-theme') }}
                        </h3>

                        <div class="tournament-meta-panel">
                            {% set color_hex = {'W': '#F8F6F1', 'U': '#0E68AB', 'B': '#564D44', 'R': '#D3202A', 'G': '#00733E', 'C': '#BEB9B2'} %}
                            {% set color_labels = {'W': 'Blanc', 'U': 'Bleu', 'B': 'Noir', 'R': 'Rouge', 'G': 'Vert', 'C': 'Incolore'} %}

                            {% set color_total = 0 %}
                            {% for code, count in global_meta.color_counts %}
                                {% set color_total = color_total + count %}
                            {% endfor %}

                            <div class="flex flex-col items-center gap-6">
                                {# SVG Pie chart #}
                                {% set circ = 251.33 %}
                                <div class="flex-shrink-0">
                                    <svg viewBox="0 0 100 100" class="w-40 h-40 tournament-pie">
                                        {% set cumulative = 0 %}
                                        {% for code, count in global_meta.color_counts %}
                                            {% set pct = count / color_total * 100 %}
                                            {% set dash = pct / 100 * circ %}
                                            {% set gap = circ - dash %}
                                            {% set offset = circ / 4 - (cumulative / 100 * circ) %}
                                            <circle cx="50" cy="50" r="40"
                                                    fill="none"
                                                    stroke="{{ color_hex[code] ?? '#6B7280' }}"
                                                    stroke-width="18"
                                                    stroke-dasharray="{{ dash }} {{ gap }}"
                                                    stroke-dashoffset="{{ offset }}"
                                                    class="tournament-pie__slice"/>
                                            {% set cumulative = cumulative + pct %}
                                        {% endfor %}
                                    </svg>
                                </div>

                                {# Legend #}
                                <div class="w-full space-y-2">
                                    {% for code, count in global_meta.color_counts %}
                                        {% set pct = (color_total > 0) ? (count / color_total * 100)|round : 0 %}
                                        <div class="flex items-center gap-2">
                                            <span class="w-3 h-3 rounded-full flex-shrink-0" style="background: {{ color_hex[code] ?? '#6B7280' }};{% if code == 'B' %} border: 1px solid rgba(255,255,255,0.15);{% endif %}"></span>
                                            <span class="text-sm text-text-secondary">{{ color_labels[code] ?? code }}</span>
                                            <span class="text-sm font-bold text-text-primary ml-auto tabular-nums">{{ count }}</span>
                                            <span class="text-xs text-text-secondary tabular-nums w-10 text-right">{{ pct }}%</span>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% endif %}

                </div>

            </div>{# /grid #}

        </div>
    </div>
</section>
{% endif %}

{% endblock %}
